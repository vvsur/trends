{
  "name": "trends",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=24 <27",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "lint": "eslint . --max-warnings=0",
    "format:check": "pnpm -r --if-present run format:check",
    "contract:generate": "pnpm --filter @trends/api-contract run generate",
    "contract:check": "pnpm --filter @trends/api-contract run check:generated",
    "seed:check": "node scripts/validate-seed-source.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "typescript-eslint": "8.60.1"
  }
}
