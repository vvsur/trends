{
  "name": "@trends/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:validate": "prisma validate",
    "seed:load": "tsx src/modules/seed/seed-loader.cli.ts",
    "seed:publish": "tsx src/modules/seed/seed-publisher.cli.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --fileParallelism=false"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@trends/api-contract": "workspace:*",
    "fastify": "5.8.5"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
