{
  "name": "@trends/api-contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript openapi/openapi.yaml -o src/generated/openapi.ts",
    "check:generated": "pnpm run generate && git diff --exit-code -- src/generated/openapi.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run check:generated"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "typescript": "6.0.3"
  }
}
